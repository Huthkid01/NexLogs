# ===========================================
# Nexlogs — Environment variables template
# Copy to .env and fill in real values (never commit .env)
# ===========================================

# --- Frontend (Vite reads root .env when developing locally) ---

VITE_USE_MOCK_DATA=false
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Live site URL (use custom domain when ready)
VITE_APP_URL=https://nexlogs.store
VITE_APP_NAME=Nexlogs

VITE_KORA_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_ADMIN_EMAIL=admin@yourdomain.com
VITE_ADMIN_PASSWORD=your-admin-password

# --- Server-side only — never expose in frontend builds ---

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_PROJECT_REF=your-project-ref

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

KORA_SECRET_KEY=your-kora-secret-key-from-dashboard

APP_URL=https://nexlogs.store
APP_NAME=Nexlogs
CLIENT_ORIGINS=https://nexlogs.store,https://www.nexlogs.store,https://nex-logs-client.vercel.app

# --- Auth emails (sign up + password reset) ---
# Configured in Supabase Dashboard only — NOT in this file:
#   Authentication → SMTP Settings → no-reply@nexlogs.store
#   Authentication → Email Templates → Confirm signup, Reset password
# See: supabase/setup/hostinger_supabase_auth.sql

# --- Transactional emails (purchase + add funds) ---
# Deployed as Supabase Edge Function — secrets go in Supabase, not Vercel.
#   supabase secrets set SMTP_USER=sales@nexlogs.store SMTP_PASS=... EMAIL_WEBHOOK_SECRET=...
#   supabase functions deploy send-transactional-email
# Then run: supabase/setup/hostinger_transactional_emails.sql
# See: DEPLOYMENT_EMAIL.md
# Optional local dev only (server/ folder):
EMAIL_WEBHOOK_SECRET=choose-a-long-random-secret

# --- Telegram order alerts (Supabase Edge Function secrets) ---

TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_ADMIN_CHAT_ID=your-chat-id
TELEGRAM_WEBHOOK_SECRET=choose-a-long-random-secret
