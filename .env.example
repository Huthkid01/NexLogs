# ===========================================
# Nexlogs — Environment variables template
# Copy to .env at repo root for local dev (Vite reads from root when developing).
# For Vercel: use client/.env.vercel.example → client/.env.vercel
# Never commit real .env files.
# ===========================================

# =============================================================================
# VERCEL (frontend) — Project Settings → Environment Variables
# Root Directory on Vercel must be: client
# Set for Production, Preview, and Development, then Redeploy.
# =============================================================================

# --- Required ---

VITE_USE_MOCK_DATA=false

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

VITE_APP_URL=https://www.nexlogs.store
VITE_APP_NAME=Nexlogs

# --- Wallet deposits (Kora redirect checkout — NGN only) ---
# Kora now initializes server-side via Supabase edge functions.
# No VITE_KORA_PUBLIC_KEY is required on the frontend for the redirect flow.

# --- Google Sign-In (public Client ID only) ---
# Client secret → Supabase Dashboard → Authentication → Providers → Google

VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Optional — local edge functions (supabase functions serve). Remove for production.
# VITE_SUPABASE_FUNCTIONS_URL=http://127.0.0.1:54321/functions/v1

# --- Admin login gate (/admin/login) ---
# Used by the admin login page before Supabase auth.

# Admin login uses Supabase Auth + profiles.role = 'admin' (no env password needed).

# --- Optional / not used in production UI ---
# Flutterwave is disabled in the app (Kora only). Leave unset unless re-enabling.

# VITE_FLUTTERWAVE_PUBLIC_KEY=

# =============================================================================
# SUPABASE EDGE FUNCTION SECRETS
# Dashboard → Project Settings → Edge Functions → Secrets
# Or CLI: supabase secrets set KEY=value --project-ref your-project-ref
# =============================================================================

# Shared (most edge functions)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

APP_URL=https://www.nexlogs.store
APP_NAME=Nexlogs

# kora-init / kora-verify / kora-webhook (required for Add Funds)
KORA_SECRET_KEY=your-kora-secret-key

# send-transactional-email (purchase + wallet deposit emails)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=sales@nexlogs.store
SMTP_PASS=your-smtp-app-password
EMAIL_FROM_ADDRESS=sales@nexlogs.store
EMAIL_FROM_NAME=Nexlogs
EMAIL_WEBHOOK_SECRET=choose-a-long-random-secret

# telegram-order-alert (optional — marketplace, RDP, SMS numbers, and wallet deposits)
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_ADMIN_CHAT_ID=your-chat-id
TELEGRAM_WEBHOOK_SECRET=choose-a-long-random-secret

# flutterwave-verify (disabled for Add Funds until migrated safely)
# FLUTTERWAVE_SECRET_KEY=

# smspool (Buy Numbers — temporary SMS verification)
SMSPOOL_API_KEY=your-smspool-api-key
FIVESIM_API_KEY=your-5sim-api-key
# Optional pricing fallbacks (Admin → SMS Pricing overrides these):
# SMSPOOL_USD_NGN_RATE=1500
# SMSPOOL_MARKUP_PERCENT=50

# Deploy after setting secrets:
#   supabase functions deploy telegram-order-alert --yes
#   supabase functions deploy smspool --yes
#   supabase functions deploy kora-init --yes
#   supabase functions deploy kora-verify --yes
#   supabase functions deploy kora-webhook --yes
#   supabase db push

# =============================================================================
# SUPABASE AUTH EMAILS (signup + password reset)
# Configured in Dashboard only — NOT in this file:
#   Authentication → SMTP Settings
#   Authentication → Email Templates
# See: supabase/setup/hostinger_supabase_auth.sql
# =============================================================================

# =============================================================================
# DATABASE
# Run migrations in Supabase SQL editor (including 053_wallet_ngn_native.sql).
# Wallet and product prices are stored in NGN after migration 053.
# =============================================================================

# =============================================================================
# LOCAL ONLY — optional server/ folder (not used if you rely on edge functions)
# =============================================================================

SUPABASE_PROJECT_REF=your-project-ref
CLIENT_ORIGINS=https://www.nexlogs.store,https://nexlogs.store,http://localhost:5173

GOOGLE_CLIENT_SECRET=your-google-client-secret

# =============================================================================
# DO NOT PUT ON VERCEL (never prefix with VITE_)
# =============================================================================
# KORA_SECRET_KEY
# SUPABASE_SERVICE_ROLE_KEY
# FLUTTERWAVE_SECRET_KEY
# SMTP_PASS
# EMAIL_WEBHOOK_SECRET
# TELEGRAM_BOT_TOKEN
# GOOGLE_CLIENT_SECRET
