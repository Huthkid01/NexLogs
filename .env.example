# ===========================================
# Nexlogs — Environment variables template
# ===========================================
#
# Frontend (copy to client/.env):
#   cp .env.example client/.env
#
# Server-side (copy to root .env):
#   cp .env.example .env
#
# Only VITE_* variables are available in the React app.

# --- Frontend (client/.env) ---

# Demo mode: use mock login + products without Supabase
VITE_USE_MOCK_DATA=true

# Supabase (Dashboard → Settings → API) — fill when connecting backend
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# App
VITE_APP_URL=http://localhost:5173
VITE_APP_NAME=Nexlogs

# --- Server-side only (root .env) — never expose in frontend ---

# Supabase service role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google OAuth (also set in Supabase Dashboard → Auth → Providers)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Optional: Supabase project reference
SUPABASE_PROJECT_REF=your-project-ref

# Flutterwave (test keys from dashboard.flutterwave.com → Settings → API Keys)
VITE_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X
FLUTTERWAVE_ENCRYPTION_KEY=FLWSECK_TESTxxxxxxxxxxxxxxxx
