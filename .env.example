# ===========================================
# Nexlogs — Environment variables template
# ===========================================

# --- Frontend ---

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_APP_URL=http://localhost:5173
VITE_APP_NAME=Nexlogs

VITE_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X
VITE_ADMIN_EMAIL=admin@yourdomain.com
VITE_ADMIN_PASSWORD=your-admin-password

# --- Server-side only (root .env) — never in frontend ---

SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
SUPABASE_PROJECT_REF=your-project-ref

FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X

# Telegram (Supabase Edge Function secrets only)
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_ADMIN_CHAT_ID=your-chat-id
TELEGRAM_WEBHOOK_SECRET=choose-a-long-random-secret

APP_URL=http://localhost:5173
APP_NAME=Nexlogs

# --- Emails: Supabase Auth + Hostinger SMTP (Dashboard only) ---
# Do NOT put Hostinger password in .env for the React app.
# Supabase Dashboard → Authentication → SMTP Settings:
#   Host: smtp.hostinger.com | Port: 465 or 587
#   User: your@domain.com | Password: mailbox / app password
# Then edit Email Templates: Confirm signup, Reset password
# See: supabase/setup/hostinger_supabase_auth.sql
