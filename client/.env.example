# ===========================================
# Nexlogs — Vercel / local frontend env
# Vercel → Settings → Environment Variables (Root Directory: client)
# Local dev: copy to client/.env or use repo root .env
# ===========================================

# --- Required ---

VITE_USE_MOCK_DATA=false

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

VITE_APP_URL=https://www.nexlogs.store
VITE_APP_NAME=Nexlogs

# Auto sign-out after inactivity (minutes). Allowed range: 30-60. Default: 45.
# VITE_SESSION_IDLE_TIMEOUT_MINUTES=45

# --- Wallet deposits (Kora redirect checkout — NGN only) ---
# No public Kora key is required on the frontend for the redirect flow.

# --- Google Sign-In (public Client ID only) ---

VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# --- Admin login gate (/admin/login) ---

# Admin login uses Supabase Auth + profiles.role = 'admin' (no env password needed).

# ===========================================
# Server-side only → Supabase Edge Function secrets (NOT Vercel)
# ===========================================
# KORA_SECRET_KEY               → kora-init / kora-verify / kora-webhook
# SUPABASE_SERVICE_ROLE_KEY     → edge functions
# SMTP_* / EMAIL_WEBHOOK_SECRET → send-transactional-email
# TELEGRAM_*                    → telegram-order-alert
# GOOGLE_CLIENT_SECRET          → Supabase Auth → Google provider
#
# Optional (Flutterwave disabled in UI and edge function):
# VITE_FLUTTERWAVE_PUBLIC_KEY   → Vercel (only if re-enabled)
# FLUTTERWAVE_SECRET_KEY        → flutterwave-verify
