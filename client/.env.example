# ===========================================
# Nexlogs — Frontend (Vite)
# For local dev, the root .env is used instead when present.
# On Vercel, set these in Project → Settings → Environment Variables.
# ===========================================

VITE_USE_MOCK_DATA=false
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

VITE_APP_URL=https://nexlogs.store
VITE_APP_NAME=Nexlogs

VITE_ADMIN_EMAIL=admin@yourdomain.com
VITE_ADMIN_PASSWORD=your-secure-admin-password

VITE_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X
