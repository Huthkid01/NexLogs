# ===========================================
# Nexlogs — Frontend (Vite)
# ===========================================

# Set to false for production (requires Supabase)
VITE_USE_MOCK_DATA=false

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# App
VITE_APP_URL=http://localhost:5173
VITE_APP_NAME=Nexlogs

# Admin login gate (used on /admin/login)
VITE_ADMIN_EMAIL=admin@yourdomain.com
VITE_ADMIN_PASSWORD=your-secure-admin-password

# Flutterwave test keys (Dashboard → Settings → API Keys → Test mode)
VITE_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X
