# ===========================================
# Nexlogs — Vercel copy/paste template
# Copy to client/.env.vercel and fill in real values (gitignored).
# Vercel → Settings → Environment Variables → Import .env
# Root Directory: client | Redeploy after saving
# ===========================================

# --- Required ---

VITE_USE_MOCK_DATA=false
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_APP_URL=https://www.nexlogs.store
VITE_APP_NAME=Nexlogs

# --- Wallet deposits (Kora — NGN only; public key) ---

VITE_KORA_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Google Sign-In ---

VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# --- Admin login gate ---

VITE_ADMIN_EMAIL=admin@yourdomain.com
VITE_ADMIN_PASSWORD=your-secure-admin-password

# ===========================================
# NOT for Vercel — set in Supabase Edge Function secrets
# ===========================================
# KORA_SECRET_KEY
# SUPABASE_SERVICE_ROLE_KEY
# SMTP_USER / SMTP_PASS / EMAIL_WEBHOOK_SECRET
# TELEGRAM_BOT_TOKEN / TELEGRAM_ADMIN_CHAT_ID / TELEGRAM_WEBHOOK_SECRET
# GOOGLE_CLIENT_SECRET (Supabase Auth → Google)
