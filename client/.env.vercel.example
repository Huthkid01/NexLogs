# ===========================================
# Nexlogs — Vercel copy/paste (TEMPLATE)
# Copy to client/.env.vercel and fill in real values.
# DO NOT commit client/.env.vercel (gitignored).
# ===========================================
#
# Vercel → Project → Settings → Environment Variables
#   • Root Directory: client
#   • Add each line below (Production + Preview + Development)
#   • Or: "Import .env" and upload client/.env.vercel
#   • Then Redeploy
#
# ===========================================

# --- Required (app won't work without these) ---

VITE_USE_MOCK_DATA=false
VITE_SUPABASE_URL=https://opmjctjzwkvwsxenddfi.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_APP_URL=https://www.nexlogs.store
VITE_APP_NAME=Nexlogs

# --- Payments (Kora Pay — public key only) ---

VITE_KORA_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Google Sign-In (public Client ID only) ---
# Get from: Google Cloud Console → Credentials → OAuth 2.0 Web client
# Secret goes in Supabase Dashboard → Authentication → Providers → Google (NOT here)

VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# --- Admin login gate (/admin/login) ---

VITE_ADMIN_EMAIL=admin@yourdomain.com
VITE_ADMIN_PASSWORD=your-secure-admin-password

# ===========================================
# DO NOT add these to Vercel (server-side only)
# ===========================================
# KORA_SECRET_KEY               → Supabase → Edge Functions → kora-verify secrets
# SUPABASE_SERVICE_ROLE_KEY     → Supabase Edge Functions secrets only
# GOOGLE_CLIENT_SECRET          → Supabase → Authentication → Providers → Google
# SMTP_* / EMAIL_WEBHOOK_SECRET → Supabase → send-transactional-email secrets
# TELEGRAM_*                    → Supabase → telegram-order-alert secrets
