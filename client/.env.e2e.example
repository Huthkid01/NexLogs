# Copy to client/.env.e2e (gitignored) for Playwright E2E tests.
#
# Local app (default): Playwright starts `npm run dev` on http://localhost:5173
# Production/staging: set E2E_BASE_URL instead (webServer is skipped)

# E2E_BASE_URL=https://www.nexlogs.store

# Required for authenticated + Buy Numbers tests
E2E_TEST_EMAIL=your-test-user@example.com
E2E_TEST_PASSWORD=your-test-password

# Optional: run live SMS Pool flow (uses real wallet balance)
# E2E_RUN_LIVE_SMS=true
